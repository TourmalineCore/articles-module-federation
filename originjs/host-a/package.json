{
  "name": "host-a",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:same-host": "tsc && vite build --mode same-host",
    "docker:build": "docker build -t host-a .",
    "docker:run": "docker run -p 4451:80 host-a",
    "preview": "vite preview --port 4001",
    "lint": "run-s lint-ts lint-eslint",
    "lint-ts": "tsc --noEmit",
    "lint-eslint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.0"
  },
  "devDependencies": {
    "@originjs/vite-plugin-federation": "^1.4.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^7.0.2",
    "@typescript-eslint/parser": "^7.0.2",
    "@vitejs/plugin-react": "^4.2.0",
    "eslint": "^8.56.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-react": "^7.34.1",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "vite": "^7.1.9"
  }
}
